# 端口号
VITE_PORT=5666

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 普通 Web 开发代理后端地址
VITE_DEV_API_TARGET=https://floletic.test.geekdance.cn/api

# VITE_GLOB_API_URL=http://vm4.geekdev.cn:9020

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
# 当前走真实 API 代理，且无 backend-mock 包，开启会拖慢启动
VITE_NITRO_MOCK=false
# VITE_NITRO_MOCK=true

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# logo 图标
VITE_APP_LOGO='/static/images/logo.png'
