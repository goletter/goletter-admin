VITE_BASE=/admin

# 接口地址：Electron 调试态通过 Vite dev server 代理到真实 API
VITE_GLOB_API_URL=/api

# Electron 调试态后端代理目标
VITE_DESKTOP_API_TARGET=https://floletic.test.geekdance.cn/api

# 是否开启 Nitro Mock服务
VITE_NITRO_MOCK=false

# 是否打开 devtools
VITE_DEVTOOLS=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# logo 图标：Vite dev server 的 public 资源从根路径访问
VITE_APP_LOGO=/static/images/logo.png
