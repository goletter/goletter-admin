VITE_BASE=./

# 接口地址
VITE_GLOB_API_URL=/api

# Electron 打包态后端代理目标
VITE_DESKTOP_API_TARGET=https://floletic.test.geekdance.cn/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# logo 图标
VITE_APP_LOGO=./static/images/logo.png

# 桌面端由 electron-builder 负责产物，不生成 dist.zip
VITE_ARCHIVER=false
